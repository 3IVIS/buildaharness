.pending-actions/

# Environment files — NEVER commit secrets
.env
.env.bak
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Vitest / coverage
coverage/

# Docker volumes (if accidentally bind-mounted)
postgres_data/
clickhouse_data/
redis_data/

# Canvas package build output (packages/canvas/dist is generated — do not commit)
packages/canvas/dist/
packages/canvas/node_modules/

# Yjs collab offline persistence (IndexedDB snapshots are local, not shared)
.yjs-*

# Claude Code local state (worktrees, session data — not project code)
.claude/

