# Copy to .env.local and fill in your values.
# VITE_ variables are bundled into the browser build — treat them as public.

# URL of the buildaharness proxy (CF Worker or Node.js server).
VITE_PROXY_URL=http://localhost:3001

# Short-lived JWT obtained from POST /auth/token on the proxy.
# WARNING: Only appropriate for development and private/internal deployments.
# Do not use VITE_AUTH_TOKEN in a publicly accessible production build —
# anyone who can load your app can read this value from the bundle.
VITE_AUTH_TOKEN=
