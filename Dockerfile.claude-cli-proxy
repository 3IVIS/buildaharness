# Dockerfile for the claude-cli-proxy service.
#
# Installs the Claude Code CLI (@anthropic-ai/claude-code) and runs the
# thin FastAPI wrapper (adapter/claude_cli_proxy.py) that exposes an
# OpenAI-compatible /v1/chat/completions endpoint backed by `claude -p`.
#
# Credentials: mount ~/.claude from the host read-only at /home/appuser/.claude
# so the CLI can authenticate without an API key in the environment.
#
#   docker compose --profile claude-cli up claude-cli-proxy

FROM python:3.12-slim

# Install Node.js (LTS) so we can install the claude CLI via npm.
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install the Claude Code CLI globally.
RUN npm install -g @anthropic-ai/claude-code

# Install only the Python deps the proxy needs.
RUN pip install --no-cache-dir fastapi uvicorn[standard] pydantic

WORKDIR /app
COPY adapter/claude_cli_proxy.py .

# Non-root user — credentials volume must be owned/accessible by this user.
RUN useradd -m appuser
USER appuser

EXPOSE 4001

HEALTHCHECK --interval=15s --timeout=5s --retries=5 --start_period=20s \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:4001/health')"

CMD ["uvicorn", "claude_cli_proxy:app", "--host", "0.0.0.0", "--port", "4001"]
