{
  "name": "@itsharness/flow-spec",
  "version": "1.0.0",
  "description": "Runtime-agnostic AI agent workflow specification — Zod schema and JSON Schema",
  "exports": {
    ".": {
      "import":  "./dist/esm/schema.js",
      "require": "./dist/cjs/schema.js",
      "types":   "./dist/schema.d.ts"
    }
  },
  "main":  "./dist/cjs/schema.js",
  "types": "./dist/schema.d.ts",
  "files": [
    "dist/",
    "schema.json",
    "schema.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.esm.json && node scripts/build-cjs.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "gen:json-schema": "node scripts/gen-json-schema.mjs",
    "validate:example": "node scripts/validate-example.cjs"
  },
  "peerDependencies": {
    "zod": ">=3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "keywords": [
    "ai-agents", "langgraph", "crewai", "mastra", "workflow", "spec", "schema"
  ],
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/itsharness/itsharness" },
  "bugs":       { "url": "https://github.com/itsharness/itsharness/issues" },
  "homepage":   "https://itsharness.com"
}
