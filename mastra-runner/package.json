{
  "name": "itsharness-mastra-runner",
  "version": "0.1.0",
  "description": "Node.js execution sidecar for Mastra-compiled itsharness workflows",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps --experimental-vm-modules dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@mastra/core": "^0.10.0",
    "@ai-sdk/openai": "^0.0.66",
    "ai": "^3.3.0",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
