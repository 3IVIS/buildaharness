# itsharness environment variables
# Copy to .env and fill in EVERY value.  Never commit .env.
#
# ALL secrets below are REQUIRED — the adapter will refuse to start if any
# are absent or still at placeholder values (Fix #3, #4).
#
# ── LLM API keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_REAL_SECRET

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the 'itsharness' Postgres user (shared across adapter + Langfuse + LiteLLM).
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Full async connection URL used by the adapter.
# Docker Compose builds this automatically from POSTGRES_PASSWORD.
# When running python main.py locally (outside Docker) you must set this explicitly.
#
# Option A — connect to the Postgres container started by docker compose:
#   DATABASE_URL=postgresql+asyncpg://itsharness:${POSTGRES_PASSWORD}@localhost:5432/itsharness
#
# Option B — use a local Postgres install:
#   DATABASE_URL=postgresql+asyncpg://itsharness:${POSTGRES_PASSWORD}@localhost:5432/itsharness
#
# Option C — SQLite (no Postgres needed, dev/test only, not supported in production):
#   DATABASE_URL=sqlite+aiosqlite:///./itsharness_dev.db
DATABASE_URL=postgresql+asyncpg://itsharness:REPLACE_WITH_REAL_PASSWORD@localhost:5432/itsharness

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=REPLACE_WITH_REAL_SECRET

# ── Langfuse (self-hosted) ────────────────────────────────────────────────────
# These are the project API keys written into the Langfuse DB on first boot.
# Any non-placeholder values work; they must match between adapter and Langfuse.
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME

# Langfuse admin account created on first boot.
LANGFUSE_ADMIN_EMAIL=admin@example.com
LANGFUSE_ADMIN_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Langfuse security secrets — generate ALL THREE before first run.
# Generate NEXTAUTH_SECRET and SALT with: openssl rand -base64 32
# Generate ENCRYPTION_KEY with:           openssl rand -hex 32
#   (must be exactly 64 hex characters)
LANGFUSE_NEXTAUTH_SECRET=REPLACE_WITH_REAL_SECRET
LANGFUSE_SALT=REPLACE_WITH_REAL_SECRET
LANGFUSE_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# ClickHouse password (shared across ClickHouse + Langfuse config)
CLICKHOUSE_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# ── CORS (Fix #9) ─────────────────────────────────────────────────────────────
# Comma-separated list of origins the adapter accepts.
# In production replace localhost:3000 with your actual canvas origin.
CORS_ORIGINS=http://localhost:3000,http://canvas:3000

# ── Job TTL (Fix #15) ─────────────────────────────────────────────────────────
# Completed/errored jobs older than this many hours are evicted from memory.
JOB_TTL_HOURS=4

# ── Security tuning ───────────────────────────────────────────────────────────
# Fix #7: JWT token lifetime in days (default 30). Set lower for higher security.
JWT_TTL_DAYS=30
# Fix #6: max request body size in bytes (default 1 MB). Prevents DOS via large specs.
MAX_BODY_BYTES=1048576

# ── Canvas .env.local (Fix #49) ──────────────────────────────────────────────
# VITE_* vars must go in .env.local (not .env) because Vite bakes them at
# dev-server start, not from Docker env.  Create .env.local in the project
# root and add:
#
#   VITE_API_URL=http://localhost:8000
#   VITE_LANGFUSE_ENABLED=true
#   VITE_LANGFUSE_PUBLIC_KEY=<same as LANGFUSE_PUBLIC_KEY above>
#   VITE_LANGFUSE_HOST=http://localhost:3001
