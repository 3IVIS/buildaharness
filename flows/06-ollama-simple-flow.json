{
  "spec_version": "0.2.0",
  "id": "ollama-simple-flow",
  "name": "Ollama Simple Flow",
  "description": "Minimal single-node flow for testing Ollama integration across all 4 runtimes. Takes a topic and returns a short explanation. No external dependencies (no vector stores, no Redis, no API keys required).",
  "runtime_hints": {
    "preferred_adapter": "langgraph",
    "compatible": [
      "langgraph",
      "mastra",
      "crewai",
      "microsoft_agent_framework"
    ]
  },
  "model_defaults": {
    "model": "mistral"
  },
  "state_schema": {
    "type": "object",
    "properties": {
      "topic": {
        "type": "string",
        "description": "Topic to explain"
      },
      "explanation": {
        "type": "string",
        "description": "Short explanation generated by the LLM"
      }
    },
    "required": [
      "topic"
    ]
  },
  "nodes": [
    {
      "id": "input",
      "type": "input",
      "label": "Input"
    },
    {
      "id": "explain",
      "type": "llm_call",
      "label": "Explain Topic",
      "system_prompt": "You are a concise educator. Answer in 2-3 sentences only.",
      "prompt_template": "Explain {{topic}} in simple terms.",
      "output_key": "explanation",
      "model": "mistral",
      "model_params": {
        "temperature": 0.7,
        "max_tokens": 256
      }
    },
    {
      "id": "output",
      "type": "output",
      "label": "Output"
    }
  ],
  "edges": [
    {
      "from": "input",
      "to": "explain"
    },
    {
      "from": "explain",
      "to": "output"
    }
  ]
}
