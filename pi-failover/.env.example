# pi-failover Configuration Example
# Copy this file to .env and set your values

# Enable/disable failover
PI_FAILOVER_ENABLED=true

# Verbose logging
PI_FAILOVER_LOGGING=true

# Primary provider settings
PI_FAILOVER_PRIMARY_PROVIDER=ollama
PI_FAILOVER_PRIMARY_MODEL=qwen3-coder-next

# Backup provider settings
PI_FAILOVER_BACKUP_PROVIDER=openai
PI_FAILOVER_BACKUP_MODEL=gpt-4o

# Timeout in seconds for primary provider
PI_FAILOVER_TIMEOUT=30

# Your API keys (these should match what you set for pi normally)
# OPENAI_API_KEY=sk-...
