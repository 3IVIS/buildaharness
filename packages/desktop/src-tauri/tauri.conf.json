{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "buildaharness-assistant",
  "version": "0.1.0",
  "identifier": "com.buildaharness.assistant",
  "build": {
    "frontendDist": "../../chat-ui/dist",
    "devUrl": "http://localhost:3010",
    "beforeDevCommand": {
      "script": "npm run dev --workspace=packages/chat-ui",
      "cwd": "../../..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "npm run build --workspace=packages/chat-ui",
      "cwd": "../../.."
    }
  },
  "app": {
    "windows": [
      {
        "title": "Assistant",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
