{
  "name": "@itsharness/canvas",
  "version": "0.1.0",
  "description": "Embeddable itsharness flow canvas — spec in, spec changes out",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build --config vite.config.lib.ts && tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "lucide-react": "^0.383.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "itsharness",
    "ai-agent",
    "flow",
    "canvas",
    "react",
    "xyflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/itsharness/itsharness",
    "directory": "packages/canvas"
  }
}
