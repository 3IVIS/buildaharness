{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "@buildaharness/harness": ["../harness/src/index.ts"],
      "@buildaharness/runtime": ["../runtime/src/index.ts"],
      "@buildaharness/canvas": ["../canvas/src/spec/schema.ts"]
    }
  },
  "include": ["src", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
