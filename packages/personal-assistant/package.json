{
  "name": "@buildaharness/personal-assistant",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "personal-assistant": "./dist/cli.js"
  },
  "scripts": {
    "build": "vite build --config vite.config.lib.ts && cp src/file-tools-mcp-server.mjs dist/file-tools-mcp-server.mjs && mkdir -p dist/lexical/patterns && cp src/lexical/patterns/*.json dist/lexical/patterns/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "eval:turn-intent": "tsx scripts/eval-turn-intent.ts"
  },
  "dependencies": {
    "@buildaharness/harness": "^0.1.0",
    "@buildaharness/runtime": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.0"
  }
}
