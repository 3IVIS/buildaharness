# Copy to .env and fill in your values before running docker compose.
# Never commit .env to version control.

# ── Secrets ───────────────────────────────────────────────────────────────────
# For CF Worker, set these via: wrangler secret put <NAME>
# For Docker/Node.js, set them here (they stay server-side).

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PROXY_SECRET=change-me-to-a-random-string

# ── Public configuration ──────────────────────────────────────────────────────
# ALLOWED_ORIGIN — the URL of your frontend app.
# Only requests from this origin are accepted (wildcard * not permitted).
ALLOWED_ORIGIN=http://localhost:5173

# PORT — Node.js server listen port (Docker only; CF Worker uses wrangler.toml [dev] port).
PORT=3001
