{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["vite/client"],
    "paths": {
      "@buildaharness/personal-assistant": ["../personal-assistant/src/index.ts"],
      "@buildaharness/runtime": ["../runtime/src/index.ts"],
      "@buildaharness/harness": ["../harness/src/index.ts"],
      "@buildaharness/canvas": ["../canvas/src/spec/schema.ts"]
    }
  },
  "include": ["src"]
}
